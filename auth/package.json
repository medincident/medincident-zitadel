{
  "name": "ilizarov-auth",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "env-cmd -f .env bun --bun next dev --turbopack -p 80",
    "build": "env-cmd -f .env bun --bun next build",
    "build:errors": "__NEXT_TEST_MODE=true next build",
    "start": "env-cmd -f .env bun --bun next start -p 80",
